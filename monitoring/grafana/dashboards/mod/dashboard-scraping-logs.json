        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [{ "options": { "match": "null", "result": { "text": "0" } }, "type": "special" }],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "green", "value": 10 }
            ]
          },
          "unit": "none"
        },
        "overrides": []
