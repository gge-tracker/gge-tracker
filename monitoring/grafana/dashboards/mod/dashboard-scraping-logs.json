      "pluginVersion": "12.2.0",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "expr": "count(count by (server) (count_over_time({service=\"internal-scraping\", event=\"run_summary\", server=~\"$server\"}[$__range])))",
