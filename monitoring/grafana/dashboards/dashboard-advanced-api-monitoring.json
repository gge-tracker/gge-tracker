          "rawSql": "SELECT\r\n  $__timeInterval(timestamp) AS t,\r\n  countIf(status >= 400) * 100.0 / count() AS error_rate\r\nFROM logs.logs\r\nWHERE\r\n  $__timeFilter(timestamp)\r\n  AND job = 'ggetracker-api'\r\nGROUP BY t\r\nORDER BY t\r\n",
          "refId": "A"
        }
      ],
      "title": "Error rate over time",
      "type": "timeseries"
