          "pluginVersion": "4.12.0",
          "queryType": "table",
          "rawSql": "SELECT\r\n  hour,\r\n  avg(reqs) AS value,\r\n  concat(toString(hour), 'h') AS metric\r\nFROM\r\n(\r\n  SELECT\r\n    toHour(timestamp) AS hour,\r\n    toDate(timestamp) AS day,\r\n    count() AS reqs\r\n  FROM logs.logs\r\n  WHERE\r\n    $__timeFilter(timestamp)\r\n    AND job = 'ggetracker-api'\r\n  GROUP BY\r\n    day,\r\n    hour\r\n)\r\nGROUP BY hour\r\nORDER BY hour\r\n",
          "refId": "A"
        }
      ],
      "title": "Hourly Activity",
      "transparent": true,
      "type": "barchart"
