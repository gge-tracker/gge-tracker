          },
          "pluginVersion": "4.14.0",
          "queryType": "table",
          "rawSql": "WITH \r\n    10 AS resolution_step\r\nSELECT\r\n    toStartOfInterval(slice_time, INTERVAL resolution_step SECOND) AS time,\r\n    count() AS active_servers\r\nFROM (\r\n    SELECT\r\n        arrayJoin(\r\n            arrayMap(\r\n                x -> toDateTime(toStartOfInterval(startTime, INTERVAL resolution_step SECOND) + (x * resolution_step)),\r\n                range(0, toUInt32(dateDiff('second', startTime, timestamp) / resolution_step) + 1)\r\n            )\r\n        ) AS slice_time\r\n    FROM logs.scrapes\r\n    WHERE timestamp >= $__fromTime AND startTime <= $__toTime\r\n)\r\nGROUP BY time\r\nORDER BY time",
          "refId": "A"
        }
      ],
      "title": "Activated Scraping Services over time",
      "transparent": true,
      "type": "timeseries"
    },
